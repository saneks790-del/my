                            check("consequence_job_exercise_enabled"),
                            check("consequence_job_exercise_rush"),
                            check("consequence_job_exercise_arrive_action_enabled"),
                            track("consequence_job_exercise_chance", 0, 100, 5),
                            track("consequence_job_exercise_pda_chance", 0, 100, 5),
                        },
                    },
                    {
                        id = "social_campfire",
                        sh = true,
                        gr = {
                            slide("ui_mcm_ap_consequences_social_campfire_title"),
                            desc("ui_mcm_ap_consequences_social_campfire_desc"),
                            check("consequence_social_campfire_enabled"),
                            check("consequence_social_campfire_rush"),
                            check("consequence_social_campfire_arrive_action_enabled"),
                            track("consequence_social_campfire_chance", 0, 100, 5),
                            track("consequence_social_campfire_pda_chance", 0, 100, 5),
                        },
                    },
                    {
                        id = "social_base",
                        sh = true,
                        gr = {
                            slide("ui_mcm_ap_consequences_social_base_title"),
                            desc("ui_mcm_ap_consequences_social_base_desc"),
                            check("consequence_social_base_enabled"),
                            check("consequence_social_base_rush"),
                            check("consequence_social_base_arrive_action_enabled"),
                            track("consequence_social_base_chance", 0, 100, 5),
                            track("consequence_social_base_pda_chance", 0, 100, 5),
                        },
                    },
                },
            },
            {
                id = "development",
                sh = true,
                gr = {
                    slide("ui_mcm_ap_development_title"),
                    desc("ui_mcm_ap_development_desc"),
                    list("log_level", {
                        {"ERROR", "error"},
                        {"WARN", "warn"},
                        {"INFO", "info"},
                        {"DEBUG", "debug"},
                    }),
                    check("map_markers"),
                },
            },
        },
    }
end

function on_game_start()
    load_config()
    RegisterScriptCallback("on_option_change", load_config)
    RegisterScriptCallback("mcm_option_restore_default", load_config)
end

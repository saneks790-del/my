    local time_since_last_seen = time_global() - npc:memory_time(enemy)
    time_table3[npc:id()] = time_global() - npc:memory_time(enemy)
    if is_monster then return false end
    if enemy_id ~= db.actor:id() then return false end
    if dist < 120 or dist >= 1500 then return false end
    if pure_enemy_distance(npc, enemy) then return false end
    if npc:alive() then
        if npc:see(db.actor) or npc:see(enemy) then
            table_npc[npc:id()] = true
        elseif (npc:see(db.actor) and db.actor:see(npc)) and dist > 1 then
            return true
        elseif (db.actor:see(npc) and (not npc:see(db.actor))) and dist > 1 then
            return false
        end
    end

    if IsStalker(npc) then
        if weapon ~= nil then
            if ranged(weapon) == true then
                dumb_table[npc:id()] = true
            else
                coward_table[npc:id()] = true
            end
        end
    end

    if npc.health <= 0.4 then
        if time_table3[npc:id()] ~= nil then
            if dist >= 120 and dist < 1000 and time_table3[npc:id()] < rnd then if swicth_table2[npc:id()] == true and enemy.health < 0.6 then return true end end
            if dist >= 1000 and time_table3[npc:id()] < rnd2 then
                if swicth_table2[npc:id()] == true and enemy.health < 0.6 then return true end
                return false
            end
        end
    end

    if last_hit_time[npc:id()] and time_global() - last_hit_time[npc:id()] < 30000 then return true end
    if table_npc[npc:id()] and time_since_last_seen >= 100 and not swicth_table2[npc:id()] then swicth_table2[npc:id()] = true end
    if verification_npc2[npc:id()] == nil then verification_npc2[npc:id()] = 0 end
    if dumb_table[npc:id()] ~= 1 then
        if (dist < 1500 and dist > 120) and time_table3[npc:id()] < rnd2 then
            if swicth_table2[npc:id()] == true and verification_npc2[npc:id()] ~= 15 then
                if verification_npc2[npc:id()] < 15 then verification_npc2[npc:id()] = verification_npc2[npc:id()] + 1 end
                return true
            end
        else
            return false
        end
        return false
    end
    return false
end

function scheme_camper_dumb(enemy, npc, actor) --( Attack\camper-scheme ) --( dumb_table )
    local weapon = npc:active_item()
    local faction = character_community(npc)
    local is_actor = enemy_id == db.actor:id()
    local is_monster = character_community(enemy2) == "zombied" or IsMonster(enemy2)
    local is_friend = character_community(db.actor) == character_community(enemy2)
    local enemy_id = db.storage[npc:id()].enemy_id
    local enemy2 = enemy_id and level.object_by_id(enemy_id)
    local pos1 = npc:position()
    local pos2 = enemy:position()
    local dist = pos1:distance_to_sqr(pos2)
    local time_in_memory = time_global()
    local time_since_seen = time_global() - npc:memory_time(enemy)
    local time_since_last_seen = time_global() - npc:memory_time(enemy)
    time_table4[npc:id()] = time_global() - npc:memory_time(enemy)
    if is_monster then return false end
    if not enemy_id or enemy_id ~= db.actor:id() then return false end
    if time_since_seen == nil or dist == nil then return false end
    if pure_enemy_distance(npc, enemy) then return false end
    if npc:alive() then
        if npc:see(db.actor) or npc:see(enemy) then
            table_npc[npc:id()] = true
        elseif (npc:see(db.actor) and db.actor:see(npc)) and dist > 1 then
            return true
        elseif (db.actor:see(npc) and (not npc:see(db.actor))) and dist > 1 then
            return false
        end
    end

    if IsStalker(npc) then
        if weapon ~= nil then
            if ranged(weapon) == true then
                dumb_table[npc:id()] = true
            else
                coward_table[npc:id()] = true
            end
        end
    end

    if npc.health <= 0.4 then
        if time_table4[npc:id()] ~= nil then
            if dist >= 120 and dist < 1000 and time_table4[npc:id()] < rnd then if swicth_table2[npc:id()] == true and enemy.health > 0.6 then return true end end
            if dist >= 1000 and time_table4[npc:id()] < rnd2 then
                if swicth_table2[npc:id()] == true and enemy.health > 0.6 then return true end
                return false
            end
        end
    end

    if last_hit_time[npc:id()] and time_global() - last_hit_time[npc:id()] < 35000 then return true end
    if verification_npc2[npc:id()] == nil then verification_npc2[npc:id()] = 0 end
    if verification_npc[npc:id()] == 15 and dist > 120 then
        if verification_npc2[npc:id()] < 15 then
            verification_npc2[npc:id()] = verification_npc2[npc:id()] + 1
        else
            verification_npc[npc:id()] = 0
            verification_npc2[npc:id()] = 0
            return false
        end
        return true
    end

    dumb_npc(npc:id())
    if is_dumb(npc:id(), dist, time_since_last_seen) and swicth_table2[npc:id()] then return true end
    if time_since_seen >= 1500 and dist >= 1500 or time_since_last_seen >= 1500 and dist >= 1500 then
        return true
    elseif time_since_seen >= 1500 and dist >= 1250 or time_since_last_seen >= 1500 and dist >= 1250 then
        return true
    elseif time_since_seen >= 1500 and dist >= 1000 or time_since_last_seen >= 1500 and dist >= 1000 then
        return true
    elseif time_since_seen >= 1500 and dist >= 880 or time_since_last_seen >= 1500 and dist >= 880 then
        return true
    elseif time_since_seen >= 1500 and dist >= 760 or time_since_last_seen >= 1500 and dist >= 760 then
        return true
    elseif time_since_seen >= 1500 and dist >= 680 or time_since_last_seen >= 1500 and dist >= 680 then
        return true
    elseif time_since_seen >= 1500 and dist >= 560 or time_since_last_seen >= 1500 and dist >= 560 then
        return true
    elseif time_since_seen >= 1500 and dist >= 480 or time_since_last_seen >= 1500 and dist >= 480 then
        return true
    elseif time_since_seen >= 1500 and dist >= 360 or time_since_last_seen >= 1500 and dist >= 360 then
        return true
    elseif time_since_seen >= 1500 and dist >= 240 or time_since_last_seen >= 1500 and dist >= 240 then
        return true
    elseif time_since_seen >= 1500 and dist >= 120 or time_since_last_seen >= 1500 and dist >= 120 then
        return true
    end
    return false
end

function scheme_stupid(enemy, npc, actor) --( Assault\monolith-scheme ) --( stupid_table )
    local weapon = npc:active_item()
    local faction = character_community(npc)
    local is_actor = enemy_id == db.actor:id()
    local is_monster = character_community(enemy2) == "zombied" or IsMonster(enemy2)
    local is_friend = character_community(db.actor) == character_community(enemy2)
    local enemy_id = db.storage[npc:id()].enemy_id
    local enemy2 = enemy_id and level.object_by_id(enemy_id)
    local pos1 = npc:position()
    local pos2 = enemy:position()
    local dist = pos1:distance_to_sqr(pos2)
    local time_in_memory = time_global()
    local time_since_seen = time_global() - npc:memory_time(enemy)
    local time_since_last_seen = time_global() - npc:memory_time(enemy)
    time_table5[npc:id()] = time_global() - npc:memory_time(enemy)
    if stupid_f[faction] then
        return true
    else
        if is_monster then return false end
        if enemy_id ~= db.actor:id() then return false end
        if pure_enemy_distance(npc, enemy) then return false end
        if last_hit_time[npc:id()] and time_global() - last_hit_time[npc:id()] < 100 then return false end
        --if table_npc[npc:id()] and time_since_last_seen < 100 and not swicth_table3[npc:id()] then swicth_table3[npc:id()] = true end
        if verification_npc3[npc:id()] == nil then verification_npc3[npc:id()] = 0 end
        if time_since_seen < 1500 and dist >= 100 or time_since_last_seen < 1500 and dist >= 100 then
        return true
        end
    return false
    end
end